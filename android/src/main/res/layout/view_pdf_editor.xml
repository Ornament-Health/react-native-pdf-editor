<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/view_port"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

        <FrameLayout
            android:id="@+id/bottom_controls"
            android:layout_width="0dp"
            android:layout_height="@dimen/pdfeditor_preview_panel_height"
            android:background="#59000000"
            android:elevation="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/edit_controls_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:elevation="2dp">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_undo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="centerInside"
                android:layout_marginEnd="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_undo"
                android:contentDescription="@string/pdfeditor_undo" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_redo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_redo"
                android:contentDescription="@string/pdfeditor_redo" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/preview_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="@dimen/pdfeditor_preview_panel_horizontal_padding"
            android:paddingEnd="@dimen/pdfeditor_preview_panel_horizontal_padding"
            android:paddingTop="@dimen/pdfeditor_preview_panel_vertical_padding"
            android:paddingBottom="@dimen/pdfeditor_preview_panel_vertical_padding"
            android:clipToPadding="false"
            android:visibility="visible"
            android:elevation="1dp" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
